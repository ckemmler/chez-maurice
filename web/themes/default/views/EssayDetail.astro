---
import Base from "@app/layouts/Base.astro";
import type { Locale } from "@app/i18n/config";
import { t, localizedPath, formatFullDate, formatDate } from "@app/i18n/utils";
import { getAlternateContentPath } from "@app/i18n/translations";
import { render } from "astro:content";

interface Props {
  essay: any;
  locale?: Locale;
}

const { essay, locale = "en" } = Astro.props;
const { Content } = await render(essay);
const alternatePath = await getAlternateContentPath("essays", essay.data.translationKey, locale);
---

<Base title={essay.data.title} description={essay.data.description} locale={locale} alternatePath={alternatePath}>
  <article>
    <header>
      <h1 class="title">{essay.data.title}</h1>
      <h2 class="intro">{essay.data.section}</h2>
      <div class="post-date">
        {formatFullDate(essay.data.date, locale)}
        {essay.data.last_updated && (
          <> · {t(locale, "essays.updated")} {formatDate(essay.data.last_updated, locale, { year: "numeric", month: "long" })}</>
        )}
      </div>
    </header>

    <div class="body-text page-content">
      <Content />
    </div>

    <footer>
      <p><a href={localizedPath(locale, "/essays")}>{t(locale, "essays.backToEssays")}</a></p>
    </footer>
  </article>
</Base>

<style>
  article {
    max-width: 65ch;
  }

  header {
    margin-bottom: var(--spacing-xl);
  }

  .title {
    font-size: 3rem;
    font-weight: 600;
    margin-bottom: 0;
    line-height: 1.1;
  }

  .intro {
    color: var(--color-text-quiet);
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 400;
    margin-top: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .body-text {
    margin-top: var(--spacing-lg);
  }

  footer {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border);
  }
</style>
