---
import Base from "@app/layouts/Base.astro";
import type { Locale } from "@app/i18n/config";
import { t, resourceItemPath, formatShortDate, stripLocalePrefix } from "@app/i18n/utils";
import { getCollection } from "astro:content";
import { isPublic } from "@app/lib/flags";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;

function isDraft(entry: { data: { flags?: string[] } }) {
  return !isPublic(entry.data);
}

const articles = await getCollection("articles", ({ data }) => (import.meta.env.DEV || isPublic(data)) && data.locale === locale)
  .then((articles) => articles.sort((a, b) => b.data.date_read.valueOf() - a.data.date_read.valueOf()));

const fiches = await getCollection("fiches", ({ data }) => data.locale === locale && data.resource_collection === "articles");
const ficheByResourceId = new Map(fiches.map((f) => [f.data.resource_id, f]));
const articleSlugs = new Set(articles.map((a) => stripLocalePrefix(a.id)));
const orphanFiches = fiches.filter((f) => !articleSlugs.has(f.data.resource_id));

// Group by source
const bySource = articles.reduce((acc, article) => {
  const source = article.data.source;
  if (!acc[source]) acc[source] = [];
  acc[source].push(article);
  return acc;
}, {} as Record<string, typeof articles>);
---

<Base title={t(locale, "articles.title")} description={t(locale, "articles.description")} locale={locale}>
  <article class="prose">
    <h1>{t(locale, "articles.title")}</h1>
    <p class="text-muted">{t(locale, "articles.description")}</p>
    <p class="draft-empty-notice text-muted">All items on this page are drafts.</p>

    {articles.length > 0 ? (
      <>
        <section>
          <h2>{t(locale, "articles.recent")}</h2>
          <ul class="article-list">
            {articles.slice(0, 10).map((article) => {
              const fiche = ficheByResourceId.get(stripLocalePrefix(article.id));
              return (
                <li data-draft={isDraft(article) ? "true" : undefined}>
                  <a href={resourceItemPath(locale, "articles", article.id)}>{article.data.title}</a>{!isDraft(article) && <span class="public-dot">•</span>}
                  {fiche && <a href={`${locale === "fr" ? "/fr" : ""}/fiches/${fiche.id.replace(/\/(en|fr)\//, "/")}`} class="fiche-link">fiche</a>}
                  {article.data.author && <span class="text-muted"> {t(locale, "books.by")} {article.data.author}</span>}
                  <span class="text-muted text-sm"> · {article.data.source}</span>
                </li>
              );
            })}
          </ul>
        </section>

        {Object.keys(bySource).length > 1 && (
          <section>
            <h2>{t(locale, "articles.bySource")}</h2>
            {Object.entries(bySource).map(([source, sourceArticles]) => (
              <details>
                <summary>{source} ({sourceArticles.length})</summary>
                <ul class="article-list">
                  {sourceArticles.map((article) => {
                    const fiche = ficheByResourceId.get(stripLocalePrefix(article.id));
                    return (
                      <li data-draft={isDraft(article) ? "true" : undefined}>
                        <a href={resourceItemPath(locale, "articles", article.id)}>{article.data.title}</a>{!isDraft(article) && <span class="public-dot">•</span>}
                        {fiche && <a href={`${locale === "fr" ? "/fr" : ""}/fiches/${fiche.id.replace(/\/(en|fr)\//, "/")}`} class="fiche-link">fiche</a>}
                      </li>
                    );
                  })}
                </ul>
              </details>
            ))}
          </section>
        )}
      </>
    ) : (
      <p class="text-muted">{t(locale, "articles.noArticlesYet")}</p>
    )}

    {orphanFiches.length > 0 && (
      <section>
        <h2>Fiches</h2>
        <ul class="article-list">
          {orphanFiches.map((fiche) => (
            <li>
              <a href={`${locale === "fr" ? "/fr" : ""}/fiches/${fiche.id.replace(/\/(en|fr)\//, "/")}`} class="fiche-link">{fiche.data.title}</a>
              <span class="text-muted text-sm"> · {formatShortDate(fiche.data.date, locale)}</span>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>

<style>
  .article-list {
    list-style: none;
    padding: 0;
  }

  .article-list li {
    margin-bottom: var(--spacing-md);
    font-size: 1.05rem;
  }

  .article-list a {
    font-size: 1.35rem;
  }

  details {
    margin-bottom: var(--spacing-md);
  }

  summary {
    cursor: pointer;
    font-family: var(--font-sans);
    font-weight: 500;
  }

  details ul {
    margin-top: var(--spacing-sm);
    padding-left: var(--spacing-lg);
  }

  :global(.prose .fiche-link) { color: #7c3aed; font-size: 0.9em; }
  :global(.dark .prose .fiche-link) { color: #a78bfa; }
</style>
