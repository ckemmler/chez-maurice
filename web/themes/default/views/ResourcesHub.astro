---
import Base from "@app/layouts/Base.astro";
import type { Locale } from "@app/i18n/config";
import { t, resourcePath } from "@app/i18n/utils";
import { getCollection } from "astro:content";
import { isPublic } from "@app/lib/flags";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;

// Lucide icon SVG paths (matching candide.me's Trouvailles page)
const icons: Record<string, string> = {
  // Book (lucide: Book)
  books: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>',
  // Globe/WWW (tabler: TbWorldWww)
  articles: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19.5 7A9 9 0 0 0 12 3a9 9 0 0 0-7.5 4"/><path d="M11.5 3a16.989 16.989 0 0 0-1.826 4"/><path d="M12.5 3a16.989 16.989 0 0 1 1.828 4"/><path d="M19.5 17a9 9 0 0 1-7.5 4a9 9 0 0 1-7.5-4"/><path d="M11.5 21a16.989 16.989 0 0 1-1.826-4"/><path d="M12.5 21a16.989 16.989 0 0 0 1.828-4"/><path d="M2 10l1 4l1.5-4L6 14l1-4"/><path d="M17 10l1 4l1.5-4L21 14l1-4"/><path d="M9.5 10l1 4l1.5-4l1.5 4l1-4"/></svg>',
  // Podcast (lucide: Podcast)
  podcasts: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16.85 18.58a9 9 0 1 0-9.7 0"/><path d="M8 14a5 5 0 1 1 8 0"/><circle cx="12" cy="11" r="1"/><path d="M13 17a1 1 0 1 0-2 0l.5 4.5a.5.5 0 1 0 1 0Z"/></svg>',
  // Clapperboard (lucide: Clapperboard)
  movies: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.2 6 3 11l-.9-2.4c-.3-1.1.3-2.2 1.3-2.5l13.5-4c1.1-.3 2.2.3 2.5 1.3Z"/><path d="m6.2 5.3 3.1 3.9"/><path d="m12.4 3.4 3.1 4"/><path d="M3 11h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/></svg>',
  // TV (lucide: Tv)
  series: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="15" x="2" y="7" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>',
  // CircleUserRound (lucide: CircleUserRound)
  people: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20a6 6 0 0 0-12 0"/><circle cx="12" cy="10" r="4"/><circle cx="12" cy="12" r="10"/></svg>',
};

// Only show categories that have content
const allCategories = ["books", "articles", "podcasts", "movies", "series", "people"] as const;
const activeCategories: { key: string; allDrafts: boolean }[] = [];
for (const col of allCategories) {
  const items = await getCollection(col, ({ data }) => (data as any).locale === locale);
  if (items.length > 0) {
    const allDrafts = items.every((i) => !isPublic(i.data as any));
    activeCategories.push({ key: col, allDrafts });
  }
}
const mid = Math.ceil(activeCategories.length / 2);
const leftColumn = activeCategories.slice(0, mid);
const rightColumn = activeCategories.slice(mid);
const allDrafts = activeCategories.length > 0 && activeCategories.every((c) => c.allDrafts);
---

<Base title={t(locale, "resources.title")} description={t(locale, "resources.description")} locale={locale}>
  <article class="resources-page">
    <h1>{t(locale, "resources.title")}</h1>
    <p>{t(locale, "resources.description")}</p>

    <p class="draft-empty-notice text-muted">All resources are drafts.</p>
    <div class="resource-grid" data-draft={allDrafts ? "true" : undefined}>
      <div class="resource-col">
        {leftColumn.map((cat) => (
          <a href={resourcePath(locale, cat.key)} class="resource-link" data-draft={cat.allDrafts ? "true" : undefined}>
            <Fragment set:html={icons[cat.key]} />
            <span class="menu-item">{t(locale, `resources.${cat.key}`)}</span>
          </a>
        ))}
      </div>
      <div class="resource-col">
        {rightColumn.map((cat) => (
          <a href={resourcePath(locale, cat.key)} class="resource-link" data-draft={cat.allDrafts ? "true" : undefined}>
            <Fragment set:html={icons[cat.key]} />
            <span class="menu-item">{t(locale, `resources.${cat.key}`)}</span>
          </a>
        ))}
      </div>
    </div>
  </article>
</Base>

<style>
  .resources-page {
    margin-top: 10vh;
  }

  @media (min-width: 768px) {
    .resources-page {
      margin-top: 15vh;
    }
  }

  .resource-grid {
    display: flex;
    width: 100%;
    margin-top: 3rem;
  }

  .resource-col {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 1rem;
  }

  .resource-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
  }

  .resource-link:hover {
    text-decoration: underline;
  }

  .menu-item {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
  }
</style>
