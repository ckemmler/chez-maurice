---
import Base from "@app/layouts/Base.astro";
import Breadcrumb from "@app/components/Breadcrumb.astro";
import type { Locale } from "@app/i18n/config";
import { t, resourcePath, formatDate } from "@app/i18n/utils";
import { getAlternateContentPath } from "@app/i18n/translations";
import { render } from "astro:content";

interface Props {
  movie: any;
  locale?: Locale;
}

const { movie, locale = "en" } = Astro.props;
const { Content } = await render(movie);
const alternatePath = await getAlternateContentPath("movies", movie.data.translationKey, locale);
---

<Base title={movie.data.title} locale={locale} alternatePath={alternatePath}>
  <article>
    {movie.data.image && (
      <div class="hero-image">
        <img src={movie.data.image} alt={movie.data.title} />
      </div>
    )}
    <header>
      <Breadcrumb locale={locale} resourceKey="movies" />
      <h1 class="title">{movie.data.title}</h1>
      {movie.data.director && (
        <h2 class="intro">{t(locale, "movies.directedBy")} {movie.data.director}</h2>
      )}
      <div class="post-date">
        {movie.data.year && <span>{movie.data.year}</span>}
        {movie.data.year && <> · </>}
        {formatDate(movie.data.date_watched, locale, { year: "numeric", month: "long" })}
        {movie.data.rating && (
          <> · <span class="rating">{"★".repeat(movie.data.rating)}{"☆".repeat(5 - movie.data.rating)}</span></>
        )}
      </div>
    </header>

    <div class="body-text">
      <Content />
    </div>

    <footer>
      <p><a href={resourcePath(locale, "movies")}>{t(locale, "movies.backToMovies")}</a></p>
    </footer>
  </article>
</Base>

<style>
  article {
    max-width: 65ch;
  }

  .hero-image {
    margin-bottom: var(--spacing-xl);
  }

  .hero-image img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 8px;
  }

  @media (max-width: 480px) {
    .hero-image img {
      max-height: 320px;
    }
  }

  header {
    margin-bottom: var(--spacing-xl);
  }

  .title {
    font-size: 3rem;
    font-weight: 600;
    margin-bottom: 0;
    line-height: 1.1;
  }

  .intro {
    color: var(--color-text-quiet);
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 400;
    font-style: italic;
    margin-top: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .rating {
    color: #d4a017;
    letter-spacing: 1px;
  }

  .body-text {
    margin-top: var(--spacing-lg);
  }

  footer {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border);
  }
</style>
