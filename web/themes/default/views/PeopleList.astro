---
import Base from "@app/layouts/Base.astro";
import type { Locale } from "@app/i18n/config";
import { t, resourceItemPath, formatShortDate, stripLocalePrefix } from "@app/i18n/utils";
import { getCollection } from "astro:content";
import { isPublic } from "@app/lib/flags";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;

function isDraft(entry: { data: { flags?: string[] } }) {
  return !isPublic(entry.data);
}

const people = await getCollection("people", ({ data }) => (import.meta.env.DEV || isPublic(data)) && data.locale === locale)
  .then((p) => p.sort((a, b) => a.data.name.localeCompare(b.data.name)));

const fiches = await getCollection("fiches", ({ data }) => data.locale === locale && data.resource_collection === "people");
const ficheByResourceId = new Map(fiches.map((f) => [f.data.resource_id, f]));
const peopleSlugs = new Set(people.map((p) => stripLocalePrefix(p.id)));
const orphanFiches = fiches.filter((f) => !peopleSlugs.has(f.data.resource_id));
---

<Base title={t(locale, "people.title")} description={t(locale, "people.description")} locale={locale}>
  <article class="prose">
    <h1>{t(locale, "people.title")}</h1>
    <p class="text-muted">{t(locale, "people.description")}</p>
    <p class="draft-empty-notice text-muted">All items on this page are drafts.</p>

    {people.length > 0 ? (
      <ul class="people-list">
        {people.map((person) => {
          const fiche = ficheByResourceId.get(stripLocalePrefix(person.id));
          return (
            <li data-draft={isDraft(person) ? "true" : undefined}>
              <a href={resourceItemPath(locale, "people", person.id)}>{person.data.name}</a>{!isDraft(person) && <span class="public-dot">•</span>}
              {fiche && <a href={`${locale === "fr" ? "/fr" : ""}/fiches/${fiche.id.replace(/\/(en|fr)\//, "/")}`} class="fiche-link">fiche</a>}
              {person.data.role && <span class="text-muted"> — {person.data.role}</span>}
              {person.data.url && (
                <> · <a href={person.data.url} target="_blank" rel="noopener" class="text-sm">{t(locale, "people.visit")}</a></>
              )}
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="text-muted">{t(locale, "people.noPeopleYet")}</p>
    )}

    {orphanFiches.length > 0 && (
      <section>
        <h2>Fiches</h2>
        <ul class="people-list">
          {orphanFiches.map((fiche) => (
            <li>
              <a href={`${locale === "fr" ? "/fr" : ""}/fiches/${fiche.id.replace(/\/(en|fr)\//, "/")}`} class="fiche-link">{fiche.data.title}</a>
              <span class="text-muted text-sm"> · {formatShortDate(fiche.data.date, locale)}</span>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>

<style>
  .people-list { list-style: none; padding: 0; }
  .people-list li { margin-bottom: var(--spacing-md); font-size: 1.05rem; }
  .people-list a { font-size: 1.35rem; }
  :global(.prose .fiche-link) { color: #7c3aed; font-size: 0.9em; }
  :global(.dark .prose .fiche-link) { color: #a78bfa; }
</style>
