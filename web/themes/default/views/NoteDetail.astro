---
import Base from "@app/layouts/Base.astro";
import LucideIcon from "@app/components/LucideIcon.astro";
import type { Locale } from "@app/i18n/config";
import { t, localizedPath, formatFullDate, stripLocalePrefix } from "@app/i18n/utils";
import { getAlternateContentPath } from "@app/i18n/translations";
import { render } from "astro:content";
import { isPublic, isEncrypted, isMoc as isMocFlag, hasFlag } from "@app/lib/flags";
import { marked } from "marked";
import fs from "node:fs";
import path from "node:path";
import { scanSubtree, countNodes } from "@app/lib/subtree-scan";
import { notesDir } from "@app/lib/garden";
import { listNotes } from "@app/lib/notes-fs";
import SubtreeViz from "@app/components/SubtreeViz.astro";

interface Props {
  note: any;
  locale?: Locale;
}

const { note, locale = "en" } = Astro.props;
// SSR garden engine: the note was read from disk and already carries rendered
// HTML (note.html). Static build: it's a content-collection entry, so render it
// through the content layer. Either way we end up with body HTML to emit.
const contentHtml: string | undefined = note.html;
const { Content } = contentHtml ? { Content: null } : await render(note);

// Read fragments from _fragments/ directory next to the parent note
const contentBase = notesDir();
const parentDir = path.join(contentBase, note.id);
const fragmentsDir = path.join(parentDir, "_fragments");

interface Fragment { summary: string; html: string }

function parseFragments(dir: string): Fragment[] {
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir)
    .filter(f => f.endsWith(".frag")).sort()
    .map(f => {
      const raw = fs.readFileSync(path.join(dir, f), "utf-8");
      const m = raw.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
      let summary = "", body = raw;
      if (m) {
        const sumLine = m[1].split("\n").find(l => l.startsWith("summary:"));
        summary = sumLine?.replace(/^summary:\s*["']?|["']?\s*$/g, "") ?? "";
        body = m[2];
      }
      return { summary, html: marked.parse(body.trim(), { async: false }) as string };
    });
}

const fragments = parseFragments(fragmentsDir);
const alternatePath = await getAlternateContentPath("notes", note.data.translationKey, locale);
const isBilan = stripLocalePrefix(note.id).startsWith("bilan-");
const isDream = note.data.tags?.some((t: string) => t.toLowerCase() === "rêve");

const WIKI_RE = /\[\[([^\]|]+?)(?:\|[^\]]+?)?\]\]/g;
const thisSlug = stripLocalePrefix(note.id);

// Build MOC metadata map for wiki-link card rendering. These are serialized to
// a JSON script tag and rendered into background-images by client JS, which the
// base-rewriting middleware can't reach — so resolve the garden base here.
// No-op at the root build (BASE_URL === "/").
const gardenBase = import.meta.env.BASE_URL.replace(/\/+$/, "");
const withBase = (p?: string) =>
  p && p.startsWith("/") && !p.startsWith(gardenBase + "/") ? `${gardenBase}${p}` : p;
const allMocs = listNotes(locale).filter((n) => isMocFlag(n.data));
const mocMeta: Record<string, { title: string; description?: string; image?: string }> = {};
for (const moc of allMocs) {
  const slug = stripLocalePrefix(moc.id);
  if (slug === thisSlug) continue; // don't include self
  mocMeta[slug] = {
    title: moc.data.title,
    description: moc.data.description,
    image: withBase(moc.data.image),
  };
}

// If this is a MOC, find non-MOC child notes from wiki-links in body
let childNotes: any[] = [];
const childSlugs = new Set<string>();
if (isMocFlag(note.data) && note.body) {
  const slugs = [...note.body.matchAll(WIKI_RE)].map(m => m[1]);
  const allNotes = listNotes(locale).filter(
    (n) => !isMocFlag(n.data) && (import.meta.env.DEV || isPublic(n.data))
  );
  const notesBySlug = new Map(allNotes.map(n => [stripLocalePrefix(n.id), n]));
  childNotes = slugs.map(s => notesBySlug.get(s)).filter((n): n is NonNullable<typeof n> => !!n);
  childNotes.forEach(n => childSlugs.add(stripLocalePrefix(n.id)));

  // Sort by order when this MOC has the backlog tag
  if (note.data.tags?.includes("backlog")) {
    childNotes.sort((a, b) => {
      const oa = a.data.order ?? Infinity;
      const ob = b.data.order ?? Infinity;
      return oa - ob;
    });
  }
}

// Split into active vs done for backlog MOCs
const isBacklog = isMocFlag(note.data) && note.data.tags?.includes("backlog");
const activeNotes = isBacklog
  ? childNotes.filter(n => n.data.status !== "done")
  : childNotes;
const doneNotes = isBacklog
  ? childNotes
      .filter(n => n.data.status === "done")
      .sort((a, b) => {
        const da = a.data.date ? new Date(a.data.date).getTime() : 0;
        const db = b.data.date ? new Date(b.data.date).getTime() : 0;
        return db - da; // most recent first
      })
  : [];

// Find parent MOC: a MOC whose body contains [[this-slug]]
let parentNote: any = null;
for (const moc of allMocs) {
  if (moc.body && [...moc.body.matchAll(WIKI_RE)].some(m => m[1] === thisSlug)) {
    parentNote = moc;
    break;
  }
}

// Subtree visualization for MOCs
const subtree = isMocFlag(note.data) ? scanSubtree(thisSlug, locale as string) : null;
const subtreeNodeCount = subtree ? countNodes(subtree) : 0;

// Journal/dream MoCs show date cards instead of icons
const isJournalMoc = isMocFlag(note.data) && (note.data.tags?.includes("journal") || note.data.tags?.includes("rêve"));
const SHORT_DAYS_FR = ["Dim", "Lun", "Mar", "Mer", "Jeu", "Ven", "Sam"];
const MONTHS_FR = ["", "Janvier", "Février", "Mars", "Avril", "Mai", "Juin", "Juillet", "Août", "Septembre", "Octobre", "Novembre", "Décembre"];
function dateCard(d: Date) {
  return { day: SHORT_DAYS_FR[d.getDay()], date: d.getDate() };
}
// Track months for separators in journal MoCs
let _lastMonth = "";
function monthSeparator(d: Date): string | null {
  const key = `${d.getFullYear()}-${d.getMonth()}`;
  if (key === _lastMonth) return null;
  _lastMonth = key;
  return `${MONTHS_FR[d.getMonth() + 1]} ${d.getFullYear()}`;
}

---

<Base title={note.data.title} description={note.data.description} locale={locale} alternatePath={alternatePath}>
  <article {...(isEncrypted(note.data) ? {"data-private": ""} : {})} {...(isDream ? {"data-dream": ""} : {})}>
    {parentNote && (
      <nav class="breadcrumb">
        <a href={localizedPath(locale, `/notes/${stripLocalePrefix(parentNote.id)}`)}>← {parentNote.data.title}</a>
      </nav>
    )}

    {isMocFlag(note.data) ? (
      <header class="moc-header" style={note.data.image ? `background-image: url(${note.data.image})` : "background: linear-gradient(135deg, #1e293b, #475569)"}>
        {subtree && subtreeNodeCount > 1 && (
          <button class="moc-tree-btn" data-open-subtree aria-label={locale === "fr" ? "Voir l'arborescence" : "View tree"}>
            <LucideIcon name="network" size={18} />
            <span class="moc-tree-btn__count">{subtreeNodeCount}</span>
          </button>
        )}
        <div class="moc-header__overlay">
          <h1 class="moc-header__title">{note.data.title}</h1>
          {note.data.description && <p class="moc-header__desc">{note.data.description}</p>}
        </div>
      </header>
    ) : (
      <header class={isBilan ? "header--bilan" : isDream ? "header--dream" : ""}>
        <h1 class="title">{note.data.title}</h1>
        {note.data.description && <h2 class="intro">{note.data.description}</h2>}
        {!isBilan && <div class="post-date">{formatFullDate(note.data.date, locale)}</div>}
      </header>
    )}

    {subtree && subtreeNodeCount > 1 && (
      <dialog class="subtree-modal" id="subtree-modal">
        <div class="subtree-modal__header">
          <h2 class="subtree-modal__title">{note.data.title}</h2>
          <button class="subtree-modal__close" data-close-subtree aria-label={locale === "fr" ? "Fermer" : "Close"}>
            <LucideIcon name="x" size={20} />
          </button>
        </div>
        <div class="subtree-modal__body">
          <SubtreeViz data={subtree} locale={locale} title={note.data.title} />
        </div>
      </dialog>
      <script is:inline>
        (() => {
          const modal = document.getElementById('subtree-modal');
          if (!modal) return;
          document.querySelector('[data-open-subtree]')?.addEventListener('click', () => modal.showModal());
          modal.querySelector('[data-close-subtree]')?.addEventListener('click', () => modal.close());
          modal.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
        })();
      </script>
    )}

    <div class="body-text page-content">
      {contentHtml ? <Fragment set:html={contentHtml} /> : <Content />}
      {fragments.map(f => (
        <details class="fragment">
          <summary class="fragment__summary">{f.summary}</summary>
          <div class="fragment__body" set:html={f.html} />
        </details>
      ))}
    </div>

    {isMocFlag(note.data) && childNotes.length > 0 && (
      <section class="child-notes">
        <ul class="child-notes__list" data-backlog={isBacklog ? "true" : undefined}>
          {activeNotes.map((child) => {
            const sep = isJournalMoc && child.data.date ? monthSeparator(new Date(child.data.date)) : null;
            return (<>
            {sep && <li class="child-notes__month-sep" aria-hidden="true">{sep}</li>}
            <li data-slug={stripLocalePrefix(child.id)} data-order={child.data.order ?? ""} data-archived={hasFlag(child.data, "archived") ? "true" : undefined}>
              {import.meta.env.DEV && isBacklog && (
                <span class="drag-handle" draggable="true" title="Drag to reorder">⠿</span>
              )}
              <a href={localizedPath(locale, `/notes/${stripLocalePrefix(child.id)}`)} class="child-link">
                {isJournalMoc && child.data.date ? (() => {
                  const dc = dateCard(new Date(child.data.date));
                  return (
                    <span class="child-link__icon child-link__date-card">
                      <span class="date-card__day">{dc.day}</span>
                      <span class="date-card__num">{dc.date}</span>
                    </span>
                  );
                })() : child.data.icon ? (
                  <span class="child-link__icon">
                    <LucideIcon name={child.data.icon} size={36} />
                  </span>
                ) : null}
                <span class="child-link__text">
                  <span class="child-link__title">
                    {child.data.title}
                    {isPublic(child.data) && <span class="public-dot">•</span>}
                    {child.data.status && child.data.tags?.includes("backlog") && (
                      <span class={`status-badge status-badge--${child.data.status}`}>{child.data.status.replace("_", " ")}</span>
                    )}
                  </span>
                  {child.data.description && (
                    <span class="child-link__desc">{child.data.description}</span>
                  )}
                </span>
              </a>
            </li>
          </>);
          })}
        </ul>

        {doneNotes.length > 0 && (
          <details class="done-section" id="done-section">
            <summary class="done-toggle">Done ({doneNotes.length})</summary>
            <ul class="child-notes__list done-notes" id="done-list">
              {doneNotes.map((child, i) => (
                <li data-slug={stripLocalePrefix(child.id)} data-order={child.data.order ?? ""} data-done-index={i} hidden={i >= 5} data-archived={hasFlag(child.data, "archived") ? "true" : undefined}>
                  <a href={localizedPath(locale, `/notes/${stripLocalePrefix(child.id)}`)} class="child-link">
                    {child.data.icon && (
                      <span class="child-link__icon">
                        <LucideIcon name={child.data.icon} size={36} />
                      </span>
                    )}
                    <span class="child-link__text">
                      <span class="child-link__title">
                        {child.data.title}
                        {isPublic(child.data) && <span class="public-dot">•</span>}
                        <span class={`status-badge status-badge--done`}>done</span>
                      </span>
                      {child.data.description && (
                        <span class="child-link__desc">{child.data.description}</span>
                      )}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
            {doneNotes.length > 5 && (
              <button class="show-more-btn" id="show-more-done" type="button">
                Show more ({doneNotes.length - 5} remaining)
              </button>
            )}
          </details>
        )}
      </section>
    )}

    <script type="application/json" id="moc-meta" set:html={JSON.stringify({ mocs: mocMeta, children: [...childSlugs] })} />
    <script is:inline>
    (function() {
      var data = JSON.parse(document.getElementById('moc-meta').textContent);
      var mocs = data.mocs;
      var children = {};
      data.children.forEach(function(s) { children[s] = true; });

      // Index server-rendered child-link <li> elements by slug for cloning
      var childCards = {};
      var archivedSlugs = {};
      var monthSepBefore = {}; // slug → month separator text
      document.querySelectorAll('.child-notes__list > li[data-slug]').forEach(function(li) {
        childCards[li.dataset.slug] = li.querySelector('.child-link');
        if (li.dataset.archived === 'true') archivedSlugs[li.dataset.slug] = true;
        var prev = li.previousElementSibling;
        if (prev && prev.classList.contains('child-notes__month-sep')) {
          monthSepBefore[li.dataset.slug] = prev.textContent;
        }
      });

      function buildMocCard(href, moc) {
        var card = document.createElement('a');
        card.href = href;
        card.className = 'moc-card moc-card--inline';
        var imgDiv = document.createElement('div');
        imgDiv.className = 'moc-card__image';
        if (moc.image) {
          imgDiv.style.backgroundImage = 'url(' + moc.image + ')';
        } else {
          imgDiv.style.background = 'linear-gradient(135deg, #1e293b, #475569)';
        }
        var bodyDiv = document.createElement('div');
        bodyDiv.className = 'moc-card__body';
        var h3 = document.createElement('h3');
        h3.className = 'moc-card__title';
        h3.innerHTML = '<svg class="moc-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>' +
          '<span class="moc-card__title-wrap">' + moc.title + '</span>';
        bodyDiv.appendChild(h3);
        if (moc.description) {
          var p = document.createElement('p');
          p.className = 'moc-card__desc';
          p.textContent = moc.description;
          bodyDiv.appendChild(p);
        }
        card.appendChild(imgDiv);
        card.appendChild(bodyDiv);
        return card;
      }

      var processed = new Set();
      var allLinks = document.querySelectorAll('a.wiki-link');
      var seen = new Set();
      var anyChildReplaced = false;

      // Replace <p> elements containing wiki-links with cards rendered in-place
      allLinks.forEach(function(a) {
        var parent = a.parentNode;
        if (!parent || parent.tagName !== 'P' || seen.has(parent)) return;
        seen.add(parent);

        // Collect links and non-link text in this <p>
        var links = [];
        var hasNonLinkContent = false;
        Array.prototype.forEach.call(parent.childNodes, function(n) {
          if (n.nodeType === 3 && n.textContent.trim()) hasNonLinkContent = true;
          if (n.nodeType === 1 && n.tagName === 'A' && n.classList.contains('wiki-link')) {
            links.push(n);
          } else if (n.nodeType === 1) {
            hasNonLinkContent = true;
          }
        });

        if (links.length === 0) return;

        // Check all links are known (moc or child)
        var allKnown = links.every(function(link) {
          var s = link.dataset.refSlug;
          return (s && mocs[s]) || (s && children[s]);
        });
        if (!allKnown) return;

        if (!hasNonLinkContent) {
          // Pure wiki-link paragraph: replace entirely with cards
          var container = document.createElement('div');
          container.className = 'moc-inline-cards';
          links.forEach(function(link) {
            var s = link.dataset.refSlug;
            if (s && mocs[s]) {
              container.appendChild(buildMocCard(link.href, mocs[s]));
            } else if (s && children[s] && childCards[s]) {
              if (monthSepBefore[s]) {
                var sep = document.createElement('div');
                sep.className = 'child-notes__month-sep';
                sep.textContent = monthSepBefore[s];
                container.appendChild(sep);
              }
              var clone = childCards[s].cloneNode(true);
              if (archivedSlugs[s]) clone.classList.add('child-link--archived');
              container.appendChild(clone);
              anyChildReplaced = true;
            }
            processed.add(link);
          });
          parent.replaceWith(container);
        } else {
          // Mixed paragraph (link + text): replace each child wiki-link with a card,
          // keep remaining text as an annotation below the card
          links.forEach(function(link) {
            var s = link.dataset.refSlug;
            if (!s) return;
            if ((s && mocs[s]) || (s && children[s] && childCards[s])) {
              var card;
              if (mocs[s]) {
                card = buildMocCard(link.href, mocs[s]);
              } else {
                card = childCards[s].cloneNode(true);
                if (archivedSlugs[s]) card.classList.add('child-link--archived');
                anyChildReplaced = true;
              }
              // Collect remaining sibling nodes as annotation
              var annotation = document.createElement('span');
              annotation.className = 'moc-inline-annotation';
              var sib = link.nextSibling;
              while (sib) {
                var next = sib.nextSibling;
                annotation.appendChild(sib);
                sib = next;
              }
              var wrapper = document.createElement('div');
              wrapper.className = 'moc-inline-cards';
              wrapper.appendChild(card);
              if (annotation.textContent.trim()) {
                // Append annotation text after the card title
                var titleEl = card.querySelector('.child-link__title') || card.querySelector('.moc-card__title-wrap');
                if (titleEl) {
                  titleEl.appendChild(document.createTextNode(' '));
                  titleEl.appendChild(annotation);
                }
              }
              parent.replaceWith(wrapper);
              processed.add(link);
            }
          });
        }
      });

      // Second pass: inline moc links in mixed content
      allLinks.forEach(function(a) {
        if (processed.has(a)) return;
        var slug = a.dataset.refSlug;
        if (slug && mocs[slug]) {
          a.classList.add('wiki-link--moc');
          a.textContent = mocs[slug].title;
        }
      });

      // Hide the separate child-notes section since children are now rendered in-place
      if (anyChildReplaced) {
        var section = document.querySelector('.child-notes');
        if (section) section.style.display = 'none';
      }
    })();
    </script>

    <script is:inline>
    (function() {
      var bar = document.querySelector('.adherence-tabs__bar');
      if (!bar) return;
      var KEY = 'adherence-active-tab';
      var container = bar.parentNode;

      // Restore saved tab
      var saved = localStorage.getItem(KEY);
      if (saved) {
        var target = container.querySelector('[data-tab="' + saved + '"]');
        var panel = container.querySelector('#' + saved);
        if (target && panel) {
          container.querySelectorAll('.adherence-tabs__btn').forEach(function(b) {
            b.classList.remove('adherence-tabs__btn--active');
          });
          container.querySelectorAll('.adherence-tabs__panel').forEach(function(p) {
            p.classList.remove('adherence-tabs__panel--active');
          });
          target.classList.add('adherence-tabs__btn--active');
          panel.classList.add('adherence-tabs__panel--active');
        }
      }

      bar.addEventListener('click', function(e) {
        var btn = e.target.closest('.adherence-tabs__btn');
        if (!btn) return;
        container.querySelectorAll('.adherence-tabs__btn').forEach(function(b) {
          b.classList.remove('adherence-tabs__btn--active');
        });
        container.querySelectorAll('.adherence-tabs__panel').forEach(function(p) {
          p.classList.remove('adherence-tabs__panel--active');
        });
        btn.classList.add('adherence-tabs__btn--active');
        var panel = container.querySelector('#' + btn.dataset.tab);
        if (panel) panel.classList.add('adherence-tabs__panel--active');
        localStorage.setItem(KEY, btn.dataset.tab);
      });
    })();
    </script>

    <script is:inline>
    (function() {
      var list = document.querySelector('.agenda-list');
      if (!list) return;
      // Same-origin by default. The private tasks overlay can inject an absolute
      // API base via <meta name="api-base" content="…"> when it runs cross-origin.
      var apiMeta = document.querySelector('meta[name="api-base"]');
      var API_BASE = (apiMeta && apiMeta.getAttribute('content')) || '';

      // ── Popover ──
      var pop = document.createElement('div');
      pop.className = 'agenda-pop';
      var POP_ACTIONS =
        '<button data-action="done" class="agenda-pop__btn agenda-pop__btn--done">Terminer</button>' +
        '<button data-action="followup" class="agenda-pop__btn agenda-pop__btn--followup">Suite…</button>' +
        '<button data-action="subtask" class="agenda-pop__btn agenda-pop__btn--subtask">Sous-tâche…</button>' +
        '<button data-action="defer" class="agenda-pop__btn agenda-pop__btn--defer">Reporter</button>' +
        '<button data-action="cancel" class="agenda-pop__btn agenda-pop__btn--cancel">Annuler</button>';
      var POP_REOPEN =
        '<button data-action="reopen" class="agenda-pop__btn agenda-pop__btn--reopen">Réouvrir</button>' +
        '<button data-action="followup" class="agenda-pop__btn agenda-pop__btn--followup">Suite…</button>' +
        '<button data-action="subtask" class="agenda-pop__btn agenda-pop__btn--subtask">Sous-tâche…</button>' +
        '<button data-action="cancel" class="agenda-pop__btn agenda-pop__btn--cancel">Annuler</button>';
      pop.innerHTML = POP_ACTIONS;
      document.body.appendChild(pop);

      // ── Inline forms (replace prompt/confirm for mobile compat) ──
      var followupForm = document.createElement('div');
      followupForm.className = 'agenda-inline-form';
      followupForm.style.display = 'none';
      followupForm.innerHTML =
        '<input type="text" class="agenda-inline-input" placeholder="Prochaine action…" />' +
        '<div class="agenda-inline-row">' +
        '<label class="agenda-inline-label"><input type="checkbox" class="agenda-inline-waiting" /> en attente</label>' +
        '<button class="agenda-inline-ok">OK</button>' +
        '<button class="agenda-inline-cancel">Annuler</button>' +
        '</div>';

      var deferForm = document.createElement('div');
      deferForm.className = 'agenda-inline-form';
      deferForm.style.display = 'none';
      deferForm.innerHTML =
        '<input type="date" class="agenda-inline-input" />' +
        '<div class="agenda-inline-row">' +
        '<button class="agenda-inline-ok">OK</button>' +
        '<button class="agenda-inline-cancel">Annuler</button>' +
        '</div>';

      var subtaskForm = document.createElement('div');
      subtaskForm.className = 'agenda-inline-form';
      subtaskForm.style.display = 'none';
      subtaskForm.innerHTML =
        '<input type="text" class="agenda-inline-input" placeholder="Sous-tâche…" />' +
        '<div class="agenda-inline-row">' +
        '<button class="agenda-inline-ok">OK</button>' +
        '<button class="agenda-inline-cancel">Annuler</button>' +
        '</div>';

      var activeItem = null;
      var activeCb = null;
      var activeTaskId = null;

      function closePop() {
        pop.classList.remove('agenda-pop--open');
        if (activeCb && !activeCb.checked) activeCb.checked = false;
        activeItem = null; activeCb = null; activeTaskId = null;
      }

      function closeInlineForms() {
        followupForm.style.display = 'none';
        deferForm.style.display = 'none';
        subtaskForm.style.display = 'none';
        if (followupForm.parentNode) followupForm.parentNode.removeChild(followupForm);
        if (deferForm.parentNode) deferForm.parentNode.removeChild(deferForm);
        if (subtaskForm.parentNode) subtaskForm.parentNode.removeChild(subtaskForm);
      }

      function showPop(item, cb, taskId) {
        closeInlineForms();
        activeItem = item; activeCb = cb; activeTaskId = taskId;
        var rect = item.getBoundingClientRect();
        pop.style.top = (rect.bottom + window.scrollY + 4) + 'px';
        pop.style.left = (rect.left + window.scrollX) + 'px';
        pop.classList.add('agenda-pop--open');
      }

      function apiCall(url, body) {
        return fetch(API_BASE + url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body || {}),
        }).then(function(r) { if (!r.ok) throw new Error(r.status); return r.json(); });
      }

      function markDone(item, cb) {
        item.classList.remove('agenda-item--partial');
        item.classList.add('agenda-item--done');
        cb.checked = true;
      }

      function swapToCheckbox(item, taskId, checked) {
        var old = item.querySelector('.agenda-partial-dot');
        if (!old) return;
        var cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.className = 'agenda-check';
        cb.dataset.taskId = taskId;
        cb.checked = !!checked;
        old.replaceWith(cb);
      }

      function swapToDot(item, taskId) {
        var old = item.querySelector('.agenda-check');
        if (!old) return;
        var dot = document.createElement('span');
        dot.className = 'agenda-partial-dot';
        dot.dataset.taskId = taskId;
        dot.textContent = '…';
        old.replaceWith(dot);
      }

      function updateParentState(parentId) {
        if (!parentId) return;
        var parentItem = list.querySelector('.agenda-item[data-task-id="' + parentId + '"]');
        if (!parentItem) return;
        // Only follow-ups affect parent partial state (not subtasks)
        var children = list.querySelectorAll('.agenda-item[data-parent-id="' + parentId + '"][data-link-type="followup"]');
        if (!children.length) return;
        var allDone = true;
        for (var i = 0; i < children.length; i++) {
          if (!children[i].classList.contains('agenda-item--done')) { allDone = false; break; }
        }
        if (!(parentItem.classList.contains('agenda-item--done') || parentItem.classList.contains('agenda-item--partial'))) return;
        if (allDone) {
          parentItem.classList.remove('agenda-item--partial');
          parentItem.classList.add('agenda-item--done');
          swapToCheckbox(parentItem, parentId, true);
        } else {
          parentItem.classList.remove('agenda-item--done');
          parentItem.classList.add('agenda-item--partial');
          swapToDot(parentItem, parentId);
        }
      }

      function makeChainItem(task, parentId, linkType) {
        var lt = linkType || 'followup';
        var label = task.status === 'waiting' ? 'en attente' : 'active';
        var n = document.createElement('div');
        n.className = 'agenda-item agenda-task agenda-item--subtask agenda-item--chain';
        n.dataset.taskId = task.id;
        if (parentId) n.dataset.parentId = parentId;
        n.dataset.linkType = lt;
        n.innerHTML =
          '<input type="checkbox" class="agenda-check" data-task-id="' + task.id + '" />' +
          '<span class="agenda-time"></span>' +
          '<span class="agenda-title">↳ ' + task.title.replace(/</g,'&lt;') + '</span>' +
          '<span class="agenda-meta">' + label + '</span>';
        return n;
      }

      // ── Delegated click handler for partial dots ──
      list.addEventListener('click', function(e) {
        var dot = e.target.closest('.agenda-partial-dot');
        if (!dot) return;
        var item = dot.closest('.agenda-item');
        var taskId = dot.dataset.taskId;
        pop.innerHTML = POP_REOPEN;
        showPop(item, dot, taskId);
      });

      // ── Delegated checkbox handler (works for dynamically added items) ──
      list.addEventListener('change', function(e) {
        var cb = e.target;
        if (!cb.classList.contains('agenda-check')) return;
        e.preventDefault();
        var item = cb.closest('.agenda-item');
        var isDone = item.classList.contains('agenda-item--done');
        cb.checked = isDone; // restore visual state
        var taskId = cb.dataset.taskId;
        pop.innerHTML = isDone ? POP_REOPEN : POP_ACTIONS;
        showPop(item, cb, taskId);
      });

      // ── Popover action buttons ──
      pop.addEventListener('click', function(e) {
        e.stopPropagation();
        var btn = e.target.closest('[data-action]');
        if (!btn) return;
        var action = btn.dataset.action;
        if (action === 'cancel') { closePop(); return; }

        var taskId = activeTaskId;
        var item = activeItem;
        var cb = activeCb;
        closePop();
        if (!taskId || !item || !cb) return;

        if (action === 'reopen') {
          var wasPartial = item.classList.contains('agenda-item--partial');
          item.classList.remove('agenda-item--done', 'agenda-item--partial');
          // Swap dot back to checkbox if needed
          if (wasPartial) { swapToCheckbox(item, taskId, false); }
          else if (cb.type === 'checkbox') { cb.checked = false; }
          var parentId = item.dataset.parentId;
          if (parentId) updateParentState(parentId);
          fetch(API_BASE + '/api/v1/tasks/' + taskId, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'active' }),
          }).then(function(r) { if (!r.ok) throw new Error(r.status); })
            .catch(function(err) {
              if (wasPartial) { item.classList.add('agenda-item--partial'); swapToDot(item, taskId); }
              else { item.classList.add('agenda-item--done'); var c = item.querySelector('.agenda-check'); if (c) c.checked = true; }
              if (parentId) updateParentState(parentId);
              alert('Erreur: ' + err.message);
            });
        }

        if (action === 'done') {
          markDone(item, cb);
          var parentId = item.dataset.parentId;
          if (parentId) updateParentState(parentId);
          apiCall('/api/v1/tasks/' + taskId + '/complete', {})
            .catch(function(err) { cb.checked = false; item.classList.remove('agenda-item--done'); if (parentId) updateParentState(parentId); alert('Erreur: ' + err.message); });
        }

        if (action === 'defer') {
          deferForm.style.display = '';
          deferForm.querySelector('input').value = '';
          item.parentNode.insertBefore(deferForm, item.nextSibling);
          deferForm.querySelector('input').focus();

          var onOk = function() { cleanup();
            var newDue = deferForm.querySelector('input').value;
            if (!newDue) return;
            fetch(API_BASE + '/api/v1/tasks/' + taskId + '/defer', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ due: newDue }),
            }).then(function(r) {
              if (!r.ok) throw new Error(r.status);
              item.classList.add('agenda-item--deferred');
              item.querySelector('.agenda-meta').textContent = '→ ' + newDue;
              cb.disabled = true;
            }).catch(function(err) { alert('Erreur: ' + err.message); });
          };
          var onCancel = function() { cleanup(); };
          var cleanup = function() {
            closeInlineForms();
            deferForm.querySelector('.agenda-inline-ok').removeEventListener('click', onOk);
            deferForm.querySelector('.agenda-inline-cancel').removeEventListener('click', onCancel);
          };
          deferForm.querySelector('.agenda-inline-ok').addEventListener('click', onOk);
          deferForm.querySelector('.agenda-inline-cancel').addEventListener('click', onCancel);
        }

        if (action === 'followup') {
          followupForm.style.display = '';
          followupForm.querySelector('input[type="text"]').value = '';
          followupForm.querySelector('.agenda-inline-waiting').checked = false;
          item.parentNode.insertBefore(followupForm, item.nextSibling);
          followupForm.querySelector('input[type="text"]').focus();

          var onOk = function() { cleanup();
            var title = followupForm.querySelector('input[type="text"]').value.trim();
            if (!title) return;
            var isWaiting = followupForm.querySelector('.agenda-inline-waiting').checked;
            // Mark as partial (started, not finished) — swap checkbox to dot
            item.classList.remove('agenda-item--done');
            item.classList.add('agenda-item--partial');
            swapToDot(item, taskId);
            var pId = item.dataset.parentId;
            if (pId) updateParentState(pId);
            apiCall('/api/v1/tasks/' + taskId + '/complete', {
              next_action: title,
              next_action_status: isWaiting ? 'waiting' : 'active',
            }).then(function(res) {
              if (res.next_task) {
                var n = makeChainItem(res.next_task, taskId);
                item.parentNode.insertBefore(n, item.nextSibling);
              }
            }).catch(function(err) { item.classList.remove('agenda-item--partial'); swapToCheckbox(item, taskId, false); if (pId) updateParentState(pId); alert('Erreur: ' + err.message); });
          };
          var onCancel = function() { cleanup(); };
          var cleanup = function() {
            closeInlineForms();
            followupForm.querySelector('.agenda-inline-ok').removeEventListener('click', onOk);
            followupForm.querySelector('.agenda-inline-cancel').removeEventListener('click', onCancel);
          };
          followupForm.querySelector('.agenda-inline-ok').addEventListener('click', onOk);
          followupForm.querySelector('.agenda-inline-cancel').addEventListener('click', onCancel);
        }

        if (action === 'subtask') {
          subtaskForm.style.display = '';
          subtaskForm.querySelector('input[type="text"]').value = '';
          // Insert after last child of this task, or after the task itself
          var lastChild = list.querySelector('.agenda-item[data-parent-id="' + taskId + '"]:last-of-type');
          var insertAfter = lastChild || item;
          insertAfter.parentNode.insertBefore(subtaskForm, insertAfter.nextSibling);
          subtaskForm.querySelector('input[type="text"]').focus();

          var onOk = function() { cleanup();
            var title = subtaskForm.querySelector('input[type="text"]').value.trim();
            if (!title) return;
            fetch(API_BASE + '/api/v1/tasks', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                title: title,
                parent_id: taskId,
                link_type: 'subtask',
                status: 'active',
                category: item.querySelector('.agenda-meta') ? item.querySelector('.agenda-meta').textContent.split('·').pop().trim() : null,
              }),
            }).then(function(r) { if (!r.ok) throw new Error(r.status); return r.json(); })
              .then(function(task) {
                var n = makeChainItem(task, taskId, 'subtask');
                var last = list.querySelector('.agenda-item[data-parent-id="' + taskId + '"]:last-of-type');
                var after = last || item;
                after.parentNode.insertBefore(n, after.nextSibling);
              })
              .catch(function(err) { alert('Erreur: ' + err.message); });
          };
          var onCancel = function() { cleanup(); };
          var cleanup = function() {
            closeInlineForms();
            subtaskForm.querySelector('.agenda-inline-ok').removeEventListener('click', onOk);
            subtaskForm.querySelector('.agenda-inline-cancel').removeEventListener('click', onCancel);
          };
          subtaskForm.querySelector('.agenda-inline-ok').addEventListener('click', onOk);
          subtaskForm.querySelector('.agenda-inline-cancel').addEventListener('click', onCancel);
        }
      });

      document.addEventListener('click', function(e) {
        if (!pop.contains(e.target) && !e.target.classList.contains('agenda-check')) closePop();
      });
      document.addEventListener('keydown', function(e) { if (e.key === 'Escape') { closePop(); closeInlineForms(); } });
    })();
    </script>

    <script is:inline>
    (function() {
      // Transaction categorization in agenda
      var txSelects = document.querySelectorAll('.agenda-tx-cat-select');
      if (!txSelects.length) return;

      var API_BASE = '';
      var meta = document.querySelector('meta[name="api-base"]');
      if (meta) API_BASE = meta.getAttribute('content') || '';

      // Handle categorization
      document.addEventListener('change', function(e) {
        var sel = e.target;
        if (!sel.classList || !sel.classList.contains('agenda-tx-cat-select')) return;
        var txId = sel.dataset.txId;
        var category = sel.value;
        if (!category) return;

        fetch(API_BASE + '/api/v1/compte/transactions/' + txId + '/categorize', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ category: category }),
        })
        .then(function(r) {
          if (!r.ok) throw new Error(r.status);
          return r.json();
        })
        .then(function() {
          var badge = document.createElement('span');
          badge.className = 'agenda-tx-cat';
          badge.textContent = category;
          sel.replaceWith(badge);
          var item = badge.closest('.agenda-transaction');
          if (item) {
            item.classList.remove('agenda-transaction--uncat');
          }
        })
        .catch(function(err) { alert('Erreur: ' + err.message); });
      });
    })();
    </script>

    {import.meta.env.DEV && note.data.tags?.includes("backlog") && (
      <script is:inline>
      (function() {
        var list = document.querySelector('.child-notes__list[data-backlog]');
        if (!list) return;
        var dragItem = null;
        var orderBefore = null;

        function getOrderSnapshot() {
          return Array.from(list.querySelectorAll('li[data-slug]')).map(function(li) {
            return li.dataset.slug;
          }).join(',');
        }

        list.querySelectorAll('.drag-handle').forEach(function(handle) {
          handle.addEventListener('dragstart', function(e) {
            dragItem = handle.closest('li');
            orderBefore = getOrderSnapshot();
            dragItem.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
          });
        });

        list.addEventListener('dragover', function(e) {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
          var target = e.target.closest ? e.target.closest('li') : null;
          if (!target || target === dragItem || !list.contains(target)) return;
          var rect = target.getBoundingClientRect();
          var midY = rect.top + rect.height / 2;
          if (e.clientY < midY) {
            list.insertBefore(dragItem, target);
          } else {
            list.insertBefore(dragItem, target.nextSibling);
          }
        });

        // Use dragend instead of drop — it always fires
        list.addEventListener('dragend', function(e) {
          if (dragItem) dragItem.classList.remove('dragging');

          // Only persist if order actually changed
          var orderAfter = getOrderSnapshot();
          if (orderBefore === orderAfter) {
            dragItem = null;
            return;
          }
          dragItem = null;

          var items = list.querySelectorAll('li[data-slug]');
          var payload = [];
          items.forEach(function(li, i) {
            li.dataset.order = (i + 1) * 10;
            payload.push({ slug: li.dataset.slug, order: (i + 1) * 10 });
          });

          fetch('/_dev/reorder-children', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: payload }),
          }).then(function(r) { return r.json(); }).then(function(data) {
            if (data.error) {
              console.error('Reorder failed:', data.error);
            } else {
              console.log('Reorder saved:', data.count, 'items');
            }
          }).catch(function(err) { console.error('Reorder failed:', err); });
        });
      })();
      </script>
    )}

    {doneNotes.length > 0 && (
      <script is:inline>
      (function() {
        var details = document.getElementById('done-section');
        if (!details) return;
        var KEY = 'backlog-done-visible';
        // Restore open/closed state
        if (localStorage.getItem(KEY) === 'true') {
          details.open = true;
        }
        details.addEventListener('toggle', function() {
          localStorage.setItem(KEY, details.open ? 'true' : 'false');
        });

        // Show-more pagination
        var btn = document.getElementById('show-more-done');
        if (!btn) return;
        var BATCH = 10;
        var shown = 5;
        var items = document.querySelectorAll('#done-list li[data-done-index]');
        var total = items.length;

        btn.addEventListener('click', function() {
          var nextLimit = shown + BATCH;
          for (var i = shown; i < Math.min(nextLimit, total); i++) {
            items[i].removeAttribute('hidden');
          }
          shown = Math.min(nextLimit, total);
          var remaining = total - shown;
          if (remaining > 0) {
            btn.textContent = 'Show more (' + remaining + ' remaining)';
          } else {
            btn.style.display = 'none';
          }
        });
      })();
      </script>
    )}

    <footer>
      <p><a href={localizedPath(locale, "/notes")}>{t(locale, "notes.backToNotes")}</a></p>
    </footer>
