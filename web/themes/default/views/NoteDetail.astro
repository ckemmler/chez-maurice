  }

  .date-card__day {
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-quiet);
  }

  .date-card__num {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .child-notes__month-sep {
    display: block !important;
    list-style: none;
    font-family: var(--font-sans, system-ui, sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 1rem 0 0.375rem;
    border-bottom: 2px solid var(--color-border, rgba(255,255,255,0.15));
    margin-bottom: 0.25rem;
  }

  .child-link__text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .child-link__title {
    font-size: 1.2rem;
    font-weight: 500;
  }

  .child-link__desc {
    font-size: 0.95rem;
    color: var(--color-text-quiet);
  }

  /* Archived child notes */
  li[data-archived="true"] .child-link,
  .child-link--archived {
    opacity: 0.45;
  }

  li[data-archived="true"] .child-link:hover,
  .child-link--archived:hover {
    opacity: 0.7;
  }

  /* Drag handles (dev-only) */
  .drag-handle {
    cursor: grab;
    user-select: none;
    font-size: 1.2rem;
    color: var(--color-text-quiet);
    opacity: 0.4;
    padding: 0 0.25rem;
    flex-shrink: 0;
  }

  .drag-handle:hover {
    opacity: 0.8;
  }

  .child-notes__list li {
    display: flex;
    align-items: center;
  }

  .child-notes__list li.dragging {
    opacity: 0.4;
  }

  /* Status badges for backlog items */
  .status-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.15em 0.5em;
    border-radius: 4px;
    margin-left: 0.5em;
    vertical-align: middle;
    background: var(--color-bg-subtle, #f1f5f9);
    color: var(--color-text-quiet);
  }

  .status-badge--proposed { background: #e2e8f0; color: #475569; }
  .status-badge--ready { background: #dbeafe; color: #1d4ed8; }
  .status-badge--in_progress { background: #fef3c7; color: #92400e; }
  .status-badge--review { background: #ede9fe; color: #6d28d9; }
  .status-badge--done { background: #d1fae5; color: #065f46; }

  :global(.dark) .status-badge--proposed,
  :root[data-theme="dark"] .status-badge--proposed { background: #334155; color: #94a3b8; }
  :global(.dark) .status-badge--ready,
  :root[data-theme="dark"] .status-badge--ready { background: #1e3a5f; color: #93c5fd; }
  :global(.dark) .status-badge--in_progress,
  :root[data-theme="dark"] .status-badge--in_progress { background: #422006; color: #fcd34d; }
  :global(.dark) .status-badge--review,
  :root[data-theme="dark"] .status-badge--review { background: #2e1065; color: #c4b5fd; }
  :global(.dark) .status-badge--done,
  :root[data-theme="dark"] .status-badge--done { background: #064e3b; color: #6ee7b7; }

  /* Done section */
  .done-section {
    margin-top: var(--spacing-lg);
  }

  .done-toggle {
    cursor: pointer;
    user-select: none;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-quiet);
    padding: var(--spacing-sm) 0;
    border-top: 1px solid var(--color-border);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.4em;
  }

  .done-toggle::-webkit-details-marker {
    display: none;
  }

  .done-toggle::before {
    content: "▸";
    display: inline-block;
    transition: transform 0.15s ease;
  }

  .done-section[open] > .done-toggle::before {
    transform: rotate(90deg);
  }

  .done-toggle:hover {
    color: var(--color-text);
  }

  .done-notes .child-link {
    opacity: 0.6;
  }

  .done-notes .child-link:hover {
    opacity: 1;
  }

  .show-more-btn {
    display: block;
    margin: var(--spacing-sm) 0;
    padding: var(--spacing-xs) var(--spacing-md);
    font-size: 0.85rem;
    font-family: var(--font-sans);
    color: var(--color-text-quiet);
    background: var(--color-bg-subtle, #f1f5f9);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .show-more-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text-quiet);
  }

  :global(.dark) .show-more-btn,
  :root[data-theme="dark"] .show-more-btn {
    background: #1e293b;
  }

  .fragment {
    border-left: 2px solid var(--color-border);
    padding-left: 0.75rem;
    margin: 1rem 0;
  }
  .fragment__summary {
    cursor: pointer;
    font-weight: 600;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-text-quiet);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.4em;
  }
  .fragment__summary::-webkit-details-marker { display: none; }
  .fragment__summary::before {
    content: "▸";
    display: inline-block;
    transition: transform 0.15s ease;
  }
  .fragment[open] > .fragment__summary::before {
    transform: rotate(90deg);
  }
  .fragment__body { margin-top: 0.5rem; }

  :global(article[data-dream]) .fragment__summary {
    font-size: 0.75rem;
    font-weight: 500;
  }

  :global(article[data-dream]) :global(h2) {
    font-size: 1rem;
    font-weight: 600;
  }

  :global(article[data-dream]) :global(h3) {
    font-size: 0.9rem;
    font-weight: 600;
  }

  footer {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border);
  }

  /* ── Adherence navigation bar ── */

  .page-content :global(.adherence-nav) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    gap: 1rem;
  }

  .page-content :global(.adherence-nav:last-child) {
    border-bottom: none;
    border-top: 1px solid var(--color-border);
    margin-top: 1.5rem;
    padding-top: 0.75rem;
  }

  .page-content :global(.adherence-nav a) {
    color: var(--color-link);
    text-decoration: none;
  }

  .page-content :global(.adherence-nav a:hover) {
    text-decoration: underline;
  }

  .page-content :global(.adherence-nav span) {
    min-width: 0;
  }

  /* ── Adherence tabs ── */

  .page-content :global(.adherence-tabs__bar) {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--color-border);
    margin-bottom: 0;
  }

  .page-content :global(.adherence-tabs__btn) {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    color: var(--color-text-quiet);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
  }

  .page-content :global(.adherence-tabs__btn:hover) {
    color: var(--color-text);
  }

  .page-content :global(.adherence-tabs__btn--active) {
    color: var(--color-link);
    border-bottom-color: var(--color-link);
  }

  .page-content :global(.adherence-tabs__btn--agenda) {
    padding: 0.4rem 0.75rem;
    display: flex;
    align-items: center;
    margin-right: auto;
  }

  .page-content :global(.adherence-tabs__panel) {
    display: none;
  }

  .page-content :global(.adherence-tabs__panel--active) {
    display: block;
  }

  .page-content :global(.adherence-tabs__panel h4 a) {
    color: inherit;
    text-decoration: none;
  }

  .page-content :global(.adherence-tabs__panel h4 a:hover) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Signal details (collapsible log) ── */

  .page-content :global(.signal-details) {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    border-left: 2px solid var(--color-border);
    padding-left: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .page-content :global(.signal-details strong) {
    color: var(--color-text-quiet);
    font-weight: 600;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .page-content :global(.signal-details ul) {
    margin: 0.15rem 0 0.6rem;
    padding-left: 1rem;
  }

  .page-content :global(.signal-details li) {
    margin: 0.1rem 0;
  }

  .page-content :global(.signal-details p) {
    margin: 0;
  }

  /* ── Sleep card ── */

  .page-content :global(.sleep-card) {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin: 1rem 0 1.5rem;
    background: var(--color-bg-alt);
  }

  .page-content :global(.sleep-header) {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .page-content :global(.sleep-icon) {
    font-size: 1rem;
  }

  .page-content :global(.sleep-total) {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .page-content :global(.sleep-time-range) {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .page-content :global(.sleep-efficiency) {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-left: auto;
  }

  .page-content :global(.sleep-bar) {
    display: flex;
    height: 10px;
    border-radius: 5px;
    overflow: hidden;
    margin-bottom: 0.6rem;
    gap: 2px;
  }

  .page-content :global(.sleep-bar__deep) {
    background: #4338ca;
    border-radius: 5px;
  }

  .page-content :global(.sleep-bar__core) {
    background: #818cf8;
    border-radius: 5px;
  }

  .page-content :global(.sleep-bar__rem) {
    background: #c4b5fd;
    border-radius: 5px;
  }

  .page-content :global(.sleep-stages) {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .page-content :global(.sleep-stage) {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .page-content :global(.sleep-dot) {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .page-content :global(.sleep-dot--deep) { background: #4338ca; }
  .page-content :global(.sleep-dot--core) { background: #818cf8; }
  .page-content :global(.sleep-dot--rem) { background: #c4b5fd; }

  /* ── Health metric cards (HRV, respiratory rate) ── */

  .page-content :global(.health-metrics-row) {
    display: flex;
    gap: 0.75rem;
    margin: 0 0 0.75rem;
  }

  .page-content :global(.health-metric-card) {
    flex: 1;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    background: var(--color-bg-alt);
  }

  .page-content :global(.health-metric-header) {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.8125rem;
  }

  .page-content :global(.health-metric-icon) {
    font-size: 0.75rem;
  }

  .page-content :global(.health-metric-label) {
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .page-content :global(.health-metric-value) {
    font-weight: 700;
    font-size: 0.9375rem;
  }

  .page-content :global(.health-metric-range) {
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    margin-left: auto;
  }

  .page-content :global(.health-sparkline) {
    width: 100%;
    height: 32px;
    display: block;
  }

  /* ── Activity card ── */

  .page-content :global(.activity-row) {
    display: flex;
    gap: 0.75rem;
    align-items: stretch;
    margin: 0 0 1.5rem;
  }

  .page-content :global(.activity-card) {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    background: var(--color-bg-alt);
  }

  .page-content :global(.activity-card--bars) {
    flex: 3;
    min-width: 0;
  }

  .page-content :global(.activity-card--donut) {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-width: 0;
    overflow: hidden;
  }

  .page-content :global(.activity-header) {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .page-content :global(.activity-icon) {
    font-size: 1rem;
  }

  .page-content :global(.activity-total) {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .page-content :global(.activity-bars) {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 40px;
  }

  .page-content :global(.activity-donut__svg) {
    width: 100%;
    max-width: 100px;
    height: auto;
  }

  .page-content :global(.activity-donut__legend) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    width: 100%;
    overflow: hidden;
  }

  .page-content :global(.activity-col) {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 100%;
    min-width: 0;
  }

  .page-content :global(.activity-col__bar) {
    width: 100%;
    border-radius: 2px 2px 0 0;
    min-height: 1px;
  }

  .page-content :global(.activity-col__hour) {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    line-height: 1;
    margin-top: 3px;
  }

  .page-content :global(.activity-legend-item) {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .page-content :global(.activity-legend-dot) {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Markdown tables (adherence grids, etc.) ── */

  .page-content :global(table) {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    border-collapse: collapse;
    margin: 1rem 0 1.5rem;
    line-height: 1.35;
  }

  .page-content :global(th),
  .page-content :global(td) {
    padding: 0.4rem 0.6rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }

  .page-content :global(th) {
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    border-bottom-width: 2px;
  }

  .page-content :global(th:first-child),
  .page-content :global(td:first-child) {
    white-space: normal;
    font-weight: 500;
  }

  .page-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .page-content :global(tbody tr:hover) {
    background: var(--color-bg-alt);
  }

  /* Scroll wrapper for wide tables (monthly grids) */
  .page-content :global(table) {
    display: block;
    overflow-x: auto;
  }

  /* ── Agenda list ── */

  .page-content :global(.agenda-list) {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 0.75rem;
  }

  .page-content :global(.agenda-empty) {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .page-content :global(.agenda-item) {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    border-left: 3px solid transparent;
  }

  .page-content :global(.agenda-item:last-child) {
    border-bottom: none;
  }

  .page-content :global(.agenda-task) {
    border-left-color: #8b5cf6;
  }

  .page-content :global(.agenda-event) {
    border-left-color: #3b82f6;
  }

  .page-content :global(.agenda-item--subtask) {
    padding-left: 2rem;
    font-size: 0.75rem;
    opacity: 0.85;
  }
  .page-content :global(.agenda-item--done) {
    opacity: 0.5;
  }

  .page-content :global(.agenda-item--done .agenda-title) {
    text-decoration: line-through;
  }

  .page-content :global(.agenda-item--partial) {
    opacity: 0.65;
    border-left-color: #f59e0b;
  }
  .page-content :global(.agenda-item--partial .agenda-title) {
    text-decoration: line-through;
    text-decoration-style: dashed;
    text-decoration-color: var(--color-text-muted);
  }
  .page-content :global(.agenda-partial-dot) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 15px;
    height: 15px;
    border-radius: 3px;
    background: #f59e0b;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    flex-shrink: 0;
    cursor: pointer;
    letter-spacing: -1px;
  }

  .page-content :global(.agenda-check) {
    accent-color: #8b5cf6;
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    cursor: pointer;
  }

  .page-content :global(.agenda-item--deferred) {
    border-left-color: #f59e0b;
    opacity: 0.6;
    font-style: italic;
  }

  .page-content :global(.agenda-item--chain) {
    border-left-color: #a78bfa;
    padding-left: calc(0.75rem + 15px + 0.6rem);
    font-style: italic;
    opacity: 0.8;
  }

  .page-content :global(.agenda-time) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    min-width: 3rem;
    flex-shrink: 0;
  }

  .page-content :global(.agenda-title) {
    flex: 1;
    min-width: 0;
  }

  .page-content :global(.agenda-meta) {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Transactions ── */

  .page-content :global(.tx-summary) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    background: rgba(245, 158, 11, 0.06);
    font-family: var(--font-sans);
  }

  .page-content :global(.tx-summary__count) {
    font-size: 0.8125rem;
    color: var(--color-text-quiet);
  }

  .page-content :global(.tx-list) {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .page-content :global(.tx-row) {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0.25rem;
    border-bottom: 1px solid var(--color-border, rgba(255,255,255,0.06));
    font-family: var(--font-sans);
  }

  .page-content :global(.tx-info) {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .page-content :global(.tx-merchant) {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .page-content :global(.tx-detail) {
    font-size: 0.6875rem;
    color: var(--color-text-quiet);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .page-content :global(.agenda-transactions) {
    margin-top: 0.75rem;
  }

  .page-content :global(.agenda-tx-header) {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    padding: 0.4rem 0.75rem 0.2rem;
  }

  .page-content :global(.agenda-transaction) {
    border-left-color: #10b981;
  }

  .page-content :global(.agenda-transaction--uncat) {
    border-left-color: #f59e0b;
    background: rgba(245, 158, 11, 0.04);
  }

  .page-content :global(.agenda-tx-amount) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
