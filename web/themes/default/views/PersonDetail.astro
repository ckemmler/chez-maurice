---
import Base from "@app/layouts/Base.astro";
import Breadcrumb from "@app/components/Breadcrumb.astro";
import type { Locale } from "@app/i18n/config";
import { t, resourcePath } from "@app/i18n/utils";
import { getAlternateContentPath } from "@app/i18n/translations";
import { render } from "astro:content";

interface Props {
  person: any;
  locale?: Locale;
}

const { person, locale = "en" } = Astro.props;
const { Content } = await render(person);
const alternatePath = await getAlternateContentPath("people", person.data.translationKey, locale);
---

<Base title={person.data.name} locale={locale} alternatePath={alternatePath}>
  <article>
    <header>
      {person.data.image && (
        <img src={person.data.image} alt={person.data.name} class="cover-image" />
      )}
      <Breadcrumb locale={locale} resourceKey="people" />
      <h1 class="title">{person.data.name}</h1>
      {person.data.role && <h2 class="intro">{person.data.role}</h2>}
      {person.data.url && (
        <div class="post-date">
          <a href={person.data.url} target="_blank" rel="noopener">{t(locale, "people.visit")}</a>
        </div>
      )}
    </header>

    <div class="body-text">
      <Content />
    </div>

    <footer>
      <p><a href={resourcePath(locale, "people")}>{t(locale, "people.backToPeople")}</a></p>
    </footer>
  </article>
</Base>

<style>
  article { max-width: 65ch; }
  header { margin-bottom: var(--spacing-xl); }
  .cover-image {
    float: right;
    max-width: 160px;
    margin: 0 0 var(--spacing-md) var(--spacing-lg);
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }
  @media (max-width: 480px) {
    .cover-image {
      float: none;
      display: block;
      margin: 0 auto var(--spacing-lg);
      max-width: 200px;
    }
  }
  .title { font-size: 3rem; font-weight: 600; margin-bottom: 0; line-height: 1.1; }
  .intro { color: var(--color-text-quiet); font-family: var(--font-sans); font-size: 1.25rem; font-weight: 400; margin-top: 0.5rem; margin-bottom: 0.25rem; }
  .body-text { margin-top: var(--spacing-lg); }
  footer { margin-top: var(--spacing-xl); padding-top: var(--spacing-lg); border-top: 1px solid var(--color-border); }
</style>
