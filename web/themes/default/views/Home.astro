---
import Base from "@app/layouts/Base.astro";
import type { Locale } from "@app/i18n/config";
import { getCollection, render } from "astro:content";
import { gardenConfig, gardenInitials } from "@app/lib/garden";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const garden = gardenConfig();

const [page] = await getCollection("pages", ({ data }) => data.translationKey === "home" && data.locale === locale);
const { Content } = page ? await render(page) : { Content: null };
---

<Base title={page?.data.title ?? garden.title} locale={locale}>
  <div class="hero">
    <div class="hero-avatar">
      {garden.avatar
        ? <img src={garden.avatar} alt={garden.name} />
        : <div class="hero-initials" aria-label={garden.name}>{gardenInitials()}</div>}
    </div>
    <div class="hero-content">
      <h1>{page?.data.title ?? garden.name}</h1>
      {Content && <Content />}
    </div>
  </div>
</Base>

<style>
  .hero {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-top: 4rem;
  }

  .hero-avatar {
    flex-shrink: 0;
  }

  .hero-avatar img {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
  }

  .hero-initials {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    font-weight: 600;
    background: var(--color-surface, #1a1a1a);
    color: var(--color-text, #f0ebe2);
    border: 1px solid var(--color-border, #333);
  }

  .hero-content {
    padding-top: 1rem;
  }

  .hero-content h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    line-height: 1.1;
  }

  .hero-content :global(p) {
    margin: 0.5rem 0;
    font-size: 1.25rem;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .hero {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1.5rem;
    }

    .hero-avatar img {
      width: 120px;
      height: 120px;
    }

    .hero-content {
      padding-top: 0;
    }
  }
</style>
