---
import BookDetail from "../../../../components/BookDetail.astro";
import { getCollection } from "astro:content";
import { isPublic } from "../../../../lib/flags";
import { stripLocalePrefix } from "../../../../i18n/utils";

export const prerender = process.env.WEB_SSR !== "1";

export async function getStaticPaths() {
  const books = await getCollection("books", ({ data }) => data.locale === "fr" && (import.meta.env.DEV || isPublic(data)));
  return books.map((book) => ({
    params: { id: stripLocalePrefix(book.id) },
    props: { book },
  }));
}

let __props = Astro.props;
if (!__props.book) {
  __props = (await getStaticPaths()).find((e) => e.params.id === Astro.params.id)?.props ?? {};
}
const { book } = __props;
if (!book) return new Response("Not found", { status: 404 });
---
<BookDetail book={book} locale="fr" />
