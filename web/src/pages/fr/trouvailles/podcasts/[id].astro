---
import PodcastDetail from "../../../../components/PodcastDetail.astro";
import { getCollection } from "astro:content";
import { isPublic } from "../../../../lib/flags";
import { stripLocalePrefix } from "../../../../i18n/utils";

export const prerender = process.env.WEB_SSR !== "1";

export async function getStaticPaths() {
  const podcasts = await getCollection("podcasts", ({ data }) => data.locale === "fr" && (import.meta.env.DEV || isPublic(data)) && !data.show);
  return podcasts.map((podcast) => ({
    params: { id: stripLocalePrefix(podcast.id) },
    props: { podcast },
  }));
}

let __props = Astro.props;
if (!__props.podcast) {
  __props = (await getStaticPaths()).find((e) => e.params.id === Astro.params.id)?.props ?? {};
}
const { podcast } = __props;
if (!podcast) return new Response("Not found", { status: 404 });
---
<PodcastDetail podcast={podcast} locale="fr" />
