---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

const locale = "fr";
const [page] = await getCollection("pages", ({ data }) => data.translationKey === "about" && data.locale === locale);
const { Content } = page ? await render(page) : { Content: null };
---

<Base title={page?.data.title ?? "À propos"} description={page?.data.description} locale={locale} alternatePath="/about">
  <article class="prose">
    {Content ? <Content /> : <p>Cette page « à propos » n'a pas encore été rédigée.</p>}
  </article>
</Base>
