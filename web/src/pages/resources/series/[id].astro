---
import SeriesDetail from "../../../components/SeriesDetail.astro";
import { getCollection } from "astro:content";
import { isPublic } from "../../../lib/flags";
import { stripLocalePrefix } from "../../../i18n/utils";

export const prerender = process.env.WEB_SSR !== "1";

export async function getStaticPaths() {
  const allSeries = await getCollection("series", ({ data }) => data.locale === "en" && (import.meta.env.DEV || isPublic(data)) && !data.show);
  return allSeries.map((series) => ({
    params: { id: stripLocalePrefix(series.id) },
    props: { series },
  }));
}

let __props = Astro.props;
if (!__props.series) {
  __props = (await getStaticPaths()).find((e) => e.params.id === Astro.params.id)?.props ?? {};
}
const { series } = __props;
if (!series) return new Response("Not found", { status: 404 });
---
<SeriesDetail series={series} locale="en" />
