# Personal data exports (e.g. Claude.ai conversation archive) — large, private
data/

# ── Private MCP tools (overlay) ──────────────────────────────────────────
# The public repo ships only the Garden tool plus gateway/shared infrastructure.
# Every other tool dir under tools/ is private: it lives in a separate private
# repo and is dropped into tools/ as an on-disk overlay, which the gateway
# discovers at runtime (see tools/mcp_gateway/server.py + tools/README.md).
# Default-deny — a new tool dir stays private until it is allow-listed below.
# Note: no trailing slash on /tools/* so the rule also catches symlinks (git
# treats a symlink-to-dir as a file), since private tools are overlaid as
# symlinks into tools/ from the maurice-tools repo.
/tools/*
!/tools/__init__.py
!/tools/README.md
!/tools/garden/
!/tools/shared/
!/tools/mcp_gateway/

# Private-tool infrastructure (qdrant is only used by private tools).
/scripts/start-qdrant.sh
/infra/launchd/com.maurice.qdrant.plist

# ── Private web exploration features (overlay) ───────────────────────────
# Early-exploration web features (the ⌘K command palette and its pages) live in
# the private maurice-web repo and are overlaid into web/ as gitignored symlinks
# (no trailing slash, so the rules also catch symlinks). The public site ships
# only the core garden. See web/src/components/Nav.astro for graceful absence.
/web/src/pages/tasks
/web/src/pages/signals
/web/src/pages/research
/web/src/pages/briefings
/web/src/pages/feeds
/web/src/pages/fiches
/web/src/pages/library
/web/src/pages/books
/web/src/pages/compte
/web/src/pages/fr/reves
/web/src/pages/fr/fiches
/web/src/components/CommandPalette.astro
/web/src/components/FichesList.astro
/web/src/lib/tasks-api.ts
/web/src/lib/dossier-api.ts
/web/src/lib/compte-api.ts
# Private full-site theme (the public repo ships the neutral `default` base +
# garden themes). The theme registry's eager glob picks it up locally, omits it
# in the public build.
/web/themes/candide

# Gardens hold personal content — default-deny. The public repo ships ONLY the
# synthetic `demo` garden + the gardens.json manifest; every real/seed garden
# (candide, family members, demo-household fixtures, anything new) stays private.
/web/gardens/*
!/web/gardens/demo/
!/web/gardens/gardens.json

# Personal research artifacts (generated; embed private workspace paths). Private.
/dossiers

# Real family-photo avatars — never publish faces. Use generic placeholders.
/design/avatars/*-sq.png
/design/import_conversations/avatars/*-sq.png
/design/landing/avatars.jpg

# Built/signed macOS .app bundle — a build artifact (embeds signing profile +
# device data). app/build is already ignored; this is a separate stray path.
/app/Maurice.app/

# build artifact (regenerated by infra/installer/build.sh)
infra/installer/ChezMaurice.pkg

# Apple notarization material — NEVER commit (private API key, certs, CSR)
notarization/
*.p8
*.p12
*.cer
*.certSigningRequest

# notarized installer artifacts (built/copied at deploy time)
*.pkg
