# Copy to .env (gitignored) and fill in. Loaded by the API server and by
# scripts/start-mcp-gateway.sh.

# Enables OAuth 2.1 on the MCP gateway so Claude Desktop / Claude.ai can add it
# as a proper remote connector (browser consent, per-tool "Allow all"). When set,
# start-mcp-gateway.sh passes --require-auth. The value only flips OAuth on —
# members authenticate by pasting their maur_* token on the consent page, which
# the gateway validates against the Maurice server. (oauth.py reads
# AKITA_OAUTH_PASSWORD for its static-key fallback, which we leave unset, so this
# is not a shared backdoor token.) Generate with: python3 -c "import secrets;print(secrets.token_urlsafe(24))"
MAURICE_OAUTH_PASSWORD=change-me

# Where the gateway validates maur_* tokens (GET /api/users/me). The Maurice
# server is HTTPS-only; the gateway calls it over loopback with TLS verify off.
MAURICE_SERVER_URL=https://127.0.0.1:3001

# ── Server (server/) ──────────────────────────────────────────────────────
# Port the API/chat server listens on.
PORT=3001
# TLS: point these at a cert + key (e.g. `tailscale cert`, or Let's Encrypt) to
# serve HTTPS; if unset/absent the server falls back to http://localhost.
# MAURICE_TLS_CERT=/path/to/server.crt
# MAURICE_TLS_KEY=/path/to/server.key
# The externally-reachable host the apps pair to (used in the server's self URL).
# MAURICE_PUBLIC_HOST=localhost

# ── Gardens (web/) ────────────────────────────────────────────────────────
# Which garden the web engine serves (folder under web/gardens/). Defaults to
# the bundled `demo` garden.
# GARDEN=demo
# Absolute path to the gardens root (production). Defaults to web/gardens/ in dev.
# MAURICE_GARDENS_DIR=/path/to/gardens
# Canonical site URL baked into the web build (sitemap/canonical). Default localhost.
# SITE_URL=https://example.com
# Hosts the Astro dev server accepts when proxied (comma-separated; leading "."
# allows subdomains). Empty by default.
# ALLOWED_HOSTS=.example.com

# ── Optional: Calibre e-book library integration ──────────────────────────
# CALIBRE_LIBRARY_PATH=/path/to/Calibre Library
